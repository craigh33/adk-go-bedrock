// This example is a repo-local leaf module. The replace directives point it at
// the in-repo core and Mantle modules so it can be run without published
// versions, and keep the anthropic-sdk-go dependency out of the core module.
replace github.com/craigh33/adk-go-bedrock => ../..

replace github.com/craigh33/adk-go-bedrock/bedrock/mantle => ../../bedrock/mantle
