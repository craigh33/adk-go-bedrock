# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Compiled example binaries
bedrock-a2a

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
# NOTE: go.work is intentionally committed. This repo is a multi-module workspace
# (root Converse module + nested bedrock/mantle module); the workspace file ties
# them together for local development and the Mantle CI job. go.work.sum stays
# ignored and is regenerated with `go work sync`.
go.work.sum

# env file
.env

# Editor/IDE
.idea/
# .vscode/
# Added by goreleaser init:
dist/

.DS_Store
*.DS_Store
